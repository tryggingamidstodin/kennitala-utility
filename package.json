{
  "name": "kennitala-utility",
  "version": "5.1.1",
  "description": "Utility functions for icelandic social security numbers (kennitolur).",
  "main": "js/index.js",
  "types": "js/index.d.ts",
  "scripts": {
    "ci": "npm run clean && npm run compile && npm run lint && npm run format && npm run test",
    "lint": "eslint .",
    "lintfix": "eslint --fix .",
    "format": "prettier --write 'src/*.ts'",
    "clean": "rm -rf js",
    "compile": "tsc",
    "build": "npm run clean && npm run compile",
    "test": "node --test --import tsx src/*.spec.ts",
    "tdd": "node --test --import tsx --watch src/*.spec.ts",
    "prepublishOnly": "npm run ci"
  },
  "keywords": [
    "kennitala",
    "kennitolur",
    "kennitölur",
    "identitynumber"
  ],
  "author": "Tryggingamidstodin <bt.hugbunadargerd@tm.is> (https://github.com/tryggingamidstodin/)",
  "files": [
    "js"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.1",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tryggingamidstodin/kennitala-utility.git"
  },
  "dependencies": {
    "oops-error": "^2.5.0"
  }
}
